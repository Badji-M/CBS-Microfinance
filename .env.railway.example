# Production Environment Variables for Railway
# Copy these to Railway Dashboard and update values

# Django Settings
SECRET_KEY=your-secret-key-change-this-in-production
DEBUG=False
ALLOWED_HOSTS=yourdomain.railway.app,*.railway.app

# Database (Railway provides this automatically)
# DATABASE_URL will be automatically set by Railway when you add PostgreSQL plugin
# But if needed, format: postgresql://user:password@host:port/dbname

# Redis (Railway provides this automatically)
# REDIS_URL will be automatically set by Railway when you add Redis plugin
CELERY_BROKER_URL=redis://:password@redis-host:port/0
CELERY_RESULT_BACKEND=redis://:password@redis-host:port/0

# Email Configuration (optional, for alerts)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
EMAIL_USE_TLS=True

# AWS S3 (optional, for media files)
USE_S3=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=

# Application Settings
CSRF_TRUSTED_ORIGINS=https://yourdomain.railway.app
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
